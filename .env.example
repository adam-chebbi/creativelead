# ══════════════════════════════════════════════════════════════════
# AutoReach V2 — Environment Variables Reference
# Copy to .env (root) on your VPS and fill in real values.
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── PostgreSQL (Docker internal) ──────────────────────────────────
POSTGRES_USER=autoreach
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=autoreach

# ── Prisma — both services connect to the same Postgres container ─
DATABASE_URL=postgresql://autoreach:change_me_strong_password@postgres:5432/autoreach
DIRECT_URL=postgresql://autoreach:change_me_strong_password@postgres:5432/autoreach

# ── NextAuth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://leads.creativecomet.tn

# ── OAuth Providers ───────────────────────────────────────────────
# GitHub: https://github.com/settings/developers
# Callback URL: https://leads.creativecomet.tn/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google: https://console.cloud.google.com/apis/credentials
# Callback URL: https://leads.creativecomet.tn/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── API Keys (stored encrypted in DB — set default fallbacks here) ─
GROQ_API_KEY=your_groq_api_key

# ── Encryption ────────────────────────────────────────────────────
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_64_hex_chars_with_node_crypto

# ── Worker Authentication ─────────────────────────────────────────
# Shared secret between Electron worker and API bridge.
# Generate with: openssl rand -hex 32
WORKER_SECRET=generate_with_openssl_rand_hex_32

# ── Resend Email ──────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=outreach@leads.creativecomet.tn
# Resend webhook signing secret — found in Resend dashboard under Webhooks
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret

# ── Application ───────────────────────────────────────────────────
APP_BASE_URL=https://leads.creativecomet.tn
NODE_ENV=production

# ══════════════════════════════════════════════════════════════════
# GitHub Actions Secrets required (set via repo Settings → Secrets):
#
#   VPS_HOST          → 54.37.159.215
#   VPS_USER          → root (or your deploy user)
#   VPS_SSH_KEY       → private SSH key for VPS access
#   WORKER_SECRET     → same value as above (injected at Electron build time)
# ══════════════════════════════════════════════════════════════════
