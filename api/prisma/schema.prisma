// AutoReach V2 — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// NEXTAUTH REQUIRED MODELS
// ─────────────────────────────────────────────────────────────
model Account {
  id                 String  @id @default(uuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  plan          String    @default("free")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  settings         UserSettings?
  businesses       Business[]
  sentEmails       SentEmail[]
  followupLogs     FollowupLog[]
  scrapingSessions ScrapingSession[]
  workerSessions   WorkerSession[]
  scrapingJobs     ScrapingJob[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// USER SETTINGS
// ─────────────────────────────────────────────────────────────
model UserSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailTemplate         String?  @map("email_template")
  followupStep3Enabled  Boolean  @default(true)  @map("followup_step3_enabled")
  followupStep7Enabled  Boolean  @default(true)  @map("followup_step7_enabled")
  followupStep14Enabled Boolean  @default(true)  @map("followup_step14_enabled")
  followupStep3Days     Int      @default(3)      @map("followup_step3_days")
  followupStep7Days     Int      @default(7)      @map("followup_step7_days")
  followupStep14Days    Int      @default(14)     @map("followup_step14_days")
  scrollDelayMin        Int      @default(800)    @map("scroll_delay_min")
  scrollDelayMax        Int      @default(1800)   @map("scroll_delay_max")
  defaultLanguage       String   @default("english") @map("default_language")
  
  // Encrypted keys
  resendApiKeyEncrypted       String?  @map("resend_api_key_encrypted")
  groqApiKeyEncrypted         String?  @map("groq_api_key_encrypted")
  googleMapsApiKeyEncrypted   String?  @map("google_maps_api_key_encrypted")
  
  resendFromEmail       String?  @map("resend_from_email")
  senderName            String?  @map("sender_name")

  @@map("user_settings")
}

// ─────────────────────────────────────────────────────────────
// BUSINESS (Lead)
// ─────────────────────────────────────────────────────────────
model Business {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  address       String   @default("")
  city          String   @default("")
  phone         String   @default("")
  website       String   @default("")
  email         String   @default("")
  googleMapsUrl String?  @map("google_maps_url")
  rating        Decimal? @db.Decimal(3, 1)
  reviewCount   Int?     @map("review_count")
  category      String   @default("")
  businessType  String   @default("") @map("business_type")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  plusCode      String?  @map("plus_code")
  photoCount    Int?     @map("photo_count")
  openingHours  Json?    @map("opening_hours")
  attributes    Json?
  popularTimes  Json?    @map("popular_times")
  stage         String   @default("New")
  notes         String?  @default("")
  unsubscribed  Boolean  @default(false)
  
  placeId       String?  @map("place_id") // Unique per user according to blueprint
  scrapeJobId   String?  @map("scrape_job_id")
  scrapeJob     ScrapingJob? @relation(fields: [scrapeJobId], references: [id])
  
  sessionId     String?  @map("session_id")
  session       ScrapingSession? @relation(fields: [sessionId], references: [id])
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  reviews      Review[]
  sentEmails   SentEmail[]
  followupLogs FollowupLog[]

  @@unique([userId, googleMapsUrl])
  @@index([userId])
  @@index([userId, stage])
  @@index([userId, city])
  @@index([userId, createdAt])
  @@map("businesses")
}

// ─────────────────────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────────────────────
model Review {
  id             String   @id @default(uuid())
  businessId     String   @map("business_id")
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  authorName     String   @map("author_name")
  authorImageUrl String?  @map("author_image_url")
  rating         Int?
  text           String?  @default("")
  publishedAt    String?  @map("published_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([businessId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────
// SCRAPING SESSION
// ─────────────────────────────────────────────────────────────
model ScrapingSession {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  city             String
  businessType     String    @map("business_type")
  maxResults       Int       @default(200) @map("max_results")
  scrapeReviews    Boolean   @default(true) @map("scrape_reviews")
  leadsCollected   Int       @default(0) @map("leads_collected")
  reviewsCollected Int       @default(0) @map("reviews_collected")
  status           String    @default("running")
  startedAt        DateTime  @default(now()) @map("started_at")
  endedAt          DateTime? @map("ended_at")
  endReason        String?   @map("end_reason")
  workerVersion    String?   @map("worker_version")

  businesses Business[]

  @@index([userId])
  @@index([userId, status])
  @@map("scraping_sessions")
}

// ─────────────────────────────────────────────────────────────
// WORKER SESSION
// ─────────────────────────────────────────────────────────────
model WorkerSession {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash     String   @map("token_hash") // Used for pairing
  
  machineName   String?  @map("machine_name")
  platform      String?
  workerVersion String?  @map("worker_version")
  
  createdAt     DateTime @default(now()) @map("created_at")
  lastSeenAt    DateTime @default(now()) @map("last_seen_at")
  status        String   @default("online")

  @@index([userId])
  @@index([userId, status])
  @@map("worker_sessions")
}

// ─────────────────────────────────────────────────────────────
// SENT EMAIL
// ─────────────────────────────────────────────────────────────
model SentEmail {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId   String?   @map("business_id")
  business     Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  businessName String    @map("business_name")
  toEmail      String    @map("to_email")
  subject      String    @default("")
  body         String    @default("")
  language     String    @default("english")
  status       String    @default("sent")
  templateId   String?   @map("template_id")
  senderEmail  String    @default("") @map("sender_email")
  sentAt       DateTime  @default(now()) @map("sent_at")

  @@index([userId])
  @@index([userId, sentAt])
  @@map("sent_emails")
}

// ─────────────────────────────────────────────────────────────
// FOLLOWUP LOG
// ─────────────────────────────────────────────────────────────
model FollowupLog {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId       String?   @map("business_id")
  business         Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  businessName     String    @map("business_name")
  toEmail          String    @map("to_email")
  originalDateSent DateTime  @map("original_date_sent")
  followupStep     Int       @map("followup_step") // 1/2/3
  status           String    @default("pending") // pending/processing/sent/skipped/replied
  scheduledFor     DateTime  @map("scheduled_for")
  subject          String    @default("")
  body             String    @default("")
  language         String    @default("english")
  sentAt           DateTime? @map("sent_at")

  @@index([userId])
  @@index([userId, status])
  @@index([userId, scheduledFor])
  @@map("followup_logs")
}

// ─────────────────────────────────────────────────────────────
// SCRAPING JOB
// ─────────────────────────────────────────────────────────────
model ScrapingJob {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  city          String
  businessType  String    @map("business_type")
  maxResults    Int       @default(200) @map("max_results")
  scrapeReviews Boolean   @default(true) @map("scrape_reviews")
  status        String    @default("queued") // queued/running/paused/completed/cancelled
  leadsCollected Int      @default(0) @map("leads_collected")
  leadsTotal    Int       @default(0) @map("leads_total")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  businesses    Business[]

  @@index([userId])
  @@index([userId, status])
  @@map("scraping_jobs")
}
