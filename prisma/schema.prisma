generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  sessions  Session[]
  workspaceMemberships WorkspaceMember[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([workspaceId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  leads     Lead[]
  campaigns Campaign[]
  auditLogs AuditLog[]
  settings      WorkspaceSettings?
  secrets       WorkspaceSecret[]
  quotaCounters QuotaCounter[]
  members       WorkspaceMember[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("owner") // owner | member
  createdAt   DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Lead {
  id             String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  businessName   String
  category       String?
  address        String?
  city           String?
  phone          String?
  website        String?
  email          String?
  rating         Float?
  reviewCount    Int?
  aiScore        Float?
  classification String?
  pipelineStage  String   @default("new")
  ownerId        String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  notes          LeadNote[]
  followUps      FollowUp[]
  attachments    LeadAttachment[]
  stageHistory   PipelineStageEntry[]

  // New AI & Score Fields
  opportunityScore    Float?
  competitionScore    Float?
  growthScore         Float?
  seoWeakness         Float?
  websiteQuality      Float?
  reviewReputation    Float?
  aiScoreLastComputed DateTime?
  aiScoreInputsHash   String?
  latitude            Float?
  longitude           Float?

  // Relations to new tables
  enrichment       LeadEnrichment?
  opportunity      LeadOpportunity?
  outreachMessages OutreachMessage[]
  websiteIntel     LeadWebsiteIntelligence?
  backgroundJobs   BackgroundJob[]

  @@index([workspaceId, pipelineStage])
  @@index([workspaceId, aiScore])
  @@index([city, category])
  @@index([latitude, longitude])
  @@index([pipelineStage])
  @@unique([workspaceId, phone])
}

model LeadEnrichment {
  id                     String    @id @default(cuid())
  leadId                 String    @unique
  lead                   Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  emails                 String[]
  additionalPhones       String[]
  linkedinUrl            String?
  facebookUrl            String?
  instagramUrl           String?
  tiktokUrl              String?
  youtubeUrl             String?
  businessSize           String?
  revenueEstimate        String?
  industryClassification String?
  generatedDescription   String?
  status                 String    @default("not_attempted")
  confidenceLevel        String?
  evidenceTrail          Json?
  lastRunAt              DateTime?
}

model LeadOpportunity {
  id                        String   @id @default(cuid())
  leadId                    String   @unique
  lead                      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  detectedGaps              Json?
  recommendedService        String?
  recommendedServiceDetails String?
  estimatedDealValue        Float?
  dealValueBreakdown        Json?
  conversionProbability     Float?
  conversionFactors         Json?
  confidenceLevel           String?
}

model OutreachMessage {
  id               String   @id @default(cuid())
  leadId           String
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel          String   // email, linkedin, whatsapp, proposal_intro
  subject          String?
  body             String
  editedByHuman    Boolean  @default(false)
  modelGeneratedBy String?
  generatedAt      DateTime @default(now())

  @@unique([leadId, channel])
}

model LeadWebsiteIntelligence {
  id                   String    @id @default(cuid())
  leadId               String    @unique
  lead                 Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reachable            Boolean?
  isHttps              Boolean?
  hasViewportMeta      Boolean?
  seoScore             Float?
  performanceScore     Float?
  loadTimeMs           Int?
  hasAnalytics         Boolean?
  analyticsTools       String[]
  hasChatbot           Boolean?
  chatbotTools         String[]
  detectedTechnologies Json?
  hasTitle             Boolean?
  hasMetaDescription   Boolean?
  hasStructuredData    Boolean?
  missingAltCount      Int?
  totalImgTags         Int?
  lastCheckedAt        DateTime?
}

model BackgroundJob {
  id           String    @id @default(cuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  jobType      String    // website-intelligence, enrichment, scoring, opportunity
  status       String    @default("queued")
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([leadId])
  @@index([status])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields:[leadId], references:[id])
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([leadId])
}

model FollowUp {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields:[leadId], references:[id])
  dueAt        DateTime
  assignedToId String
  status       String   @default("pending")

  @@index([leadId])
  @@index([status])
}

model LeadAttachment {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields:[leadId], references:[id])
  fileUrl      String
  uploadedById String

  @@index([leadId])
}

model PipelineStageEntry {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields:[leadId], references:[id])
  stage      String
  enteredAt  DateTime @default(now())
  movedById  String
}

model Campaign {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  name        String
  channel     String
  status      String       @default("draft")
  createdById String
  createdAt   DateTime     @default(now())
  ledgerEntries CampaignLedgerEntry[]

  @@index([workspaceId])
}

model CampaignLedgerEntry {
  id              String    @id @default(cuid())
  campaignId      String
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadUrl         String?
  businessName    String?
  channel         String?
  recipient       String?
  status          String    @default("pending") // pending | sent | failed | replied
  subject         String?
  body            String?
  nextScheduledAt DateTime?
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([campaignId])
  @@index([status])
}

model WorkspaceSettings {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  settings    Json
  updatedAt   DateTime @updatedAt
  updatedById String?
}

model WorkspaceSecret {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key            String   // e.g. "ai/openai", "ai/gemini", "smtp", "twilio", "google-sheets"
  encryptedValue String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

model QuotaCounter {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  metric      String   // leads_ingested | enrichment_runs | crm_exports | outreach_generations | campaign_sends
  date        DateTime // midnight UTC
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, metric, date])
  @@index([workspaceId, date])
}

model AuditLog {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  actorId        String
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([workspaceId, createdAt])
}
