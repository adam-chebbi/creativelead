generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id            // Clerk orgId
  name      String
  createdAt DateTime @default(now())
  leads     Lead[]
  campaigns Campaign[]
  auditLogs AuditLog[]
  settings  OrganizationSettings?
}

model Lead {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  businessName   String
  category       String?
  address        String?
  city           String?
  phone          String?
  website        String?
  email          String?
  rating         Float?
  reviewCount    Int?
  aiScore        Float?
  classification String?
  pipelineStage  String   @default("new")
  ownerId        String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  notes          LeadNote[]
  followUps      FollowUp[]
  attachments    LeadAttachment[]
  stageHistory   PipelineStageEntry[]

  // New AI & Score Fields
  opportunityScore    Float?
  competitionScore    Float?
  growthScore         Float?
  seoWeakness         Float?
  websiteQuality      Float?
  reviewReputation    Float?
  aiScoreLastComputed DateTime?
  aiScoreInputsHash   String?
  latitude            Float?
  longitude           Float?

  // Relations to new tables
  enrichment       LeadEnrichment?
  opportunity      LeadOpportunity?
  outreachMessages OutreachMessage[]
  websiteIntel     LeadWebsiteIntelligence?
  backgroundJobs   BackgroundJob[]

  @@index([organizationId, pipelineStage])
  @@index([organizationId, aiScore])
  @@index([city, category])
  @@index([latitude, longitude])
  @@index([pipelineStage])
  @@unique([organizationId, phone])
}

model LeadEnrichment {
  id                     String    @id @default(cuid())
  leadId                 String    @unique
  lead                   Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  emails                 String[]
  additionalPhones       String[]
  linkedinUrl            String?
  facebookUrl            String?
  instagramUrl           String?
  tiktokUrl              String?
  youtubeUrl             String?
  businessSize           String?
  revenueEstimate        String?
  industryClassification String?
  generatedDescription   String?
  status                 String    @default("not_attempted")
  confidenceLevel        String?
  evidenceTrail          Json?
  lastRunAt              DateTime?
}

model LeadOpportunity {
  id                        String   @id @default(cuid())
  leadId                    String   @unique
  lead                      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  detectedGaps              Json?
  recommendedService        String?
  recommendedServiceDetails String?
  estimatedDealValue        Float?
  dealValueBreakdown        Json?
  conversionProbability     Float?
  conversionFactors         Json?
  confidenceLevel           String?
}

model OutreachMessage {
  id               String   @id @default(cuid())
  leadId           String
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel          String   // email, linkedin, whatsapp, proposal_intro
  subject          String?
  body             String
  editedByHuman    Boolean  @default(false)
  modelGeneratedBy String?
  generatedAt      DateTime @default(now())

  @@unique([leadId, channel])
}

model LeadWebsiteIntelligence {
  id                   String    @id @default(cuid())
  leadId               String    @unique
  lead                 Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reachable            Boolean?
  isHttps              Boolean?
  hasViewportMeta      Boolean?
  seoScore             Float?
  performanceScore     Float?
  loadTimeMs           Int?
  hasAnalytics         Boolean?
  analyticsTools       String[]
  hasChatbot           Boolean?
  chatbotTools         String[]
  detectedTechnologies Json?
  hasTitle             Boolean?
  hasMetaDescription   Boolean?
  hasStructuredData    Boolean?
  missingAltCount      Int?
  totalImgTags         Int?
  lastCheckedAt        DateTime?
}

model BackgroundJob {
  id           String    @id @default(cuid())
  leadId       String
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  jobType      String    // website-intelligence, enrichment, scoring, opportunity
  status       String    @default("queued")
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([leadId])
  @@index([status])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields:[leadId], references:[id])
  authorId  String
  body      String
  createdAt DateTime @default(now())

  @@index([leadId])
}

model FollowUp {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields:[leadId], references:[id])
  dueAt        DateTime
  assignedToId String
  status       String   @default("pending")

  @@index([leadId])
  @@index([status])
}

model LeadAttachment {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields:[leadId], references:[id])
  fileUrl      String
  uploadedById String

  @@index([leadId])
}

model PipelineStageEntry {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields:[leadId], references:[id])
  stage      String
  enteredAt  DateTime @default(now())
  movedById  String
}

model Campaign {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  channel        String
  status         String       @default("draft")
  createdById    String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model OrganizationSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  settings       Json
  updatedAt      DateTime @updatedAt
  updatedById    String?
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  actorId        String
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
