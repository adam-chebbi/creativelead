{
  "name": "autoreach-worker",
  "version": "2.0.0",
  "description": "AutoReach V2 Desktop Worker",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -p tsconfig.main.json -w\" \"tsc -p tsconfig.renderer.json -w\" \"electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:main && npm run build:renderer",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1",
    "playwright": "^1.44.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  },
  "build": {
    "appId": "dev.autoreach.worker",
    "productName": "AutoReach Worker",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "src/renderer/index.html"],
    "win":   { "target": "nsis",     "icon": "assets/icon.ico" },
    "mac":   { "target": "dmg",      "icon": "assets/icon.icns" },
    "linux": { "target": "AppImage", "icon": "assets/icon.png" },
    "publish": { "provider": "github", "releaseType": "release" },
    "extraMetadata": { "apiBaseUrl": "https://api.autoreach.dev" }
  }
}
